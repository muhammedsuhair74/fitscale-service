{
  "info": {
    "name": "Fitscale Backend API",
    "description": "API collection for the Fitscale backend.\n\n- Auth uses httpOnly cookies (`accessToken`, `refreshToken`). Log in first; Postman sends cookies automatically on later requests.\n- Protected routes (Users, Workouts) require a valid `accessToken` cookie.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Health check. Returns { success, message }."
      },
      "response": []
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Registers a new user. Body: { email, password }. Returns 201 with the created user."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Capture the auth cookies set by the login response into collection variables.",
                  "const accessToken = pm.cookies.get('accessToken');",
                  "const refreshToken = pm.cookies.get('refreshToken');",
                  "if (accessToken) pm.collectionVariables.set('accessToken', accessToken);",
                  "if (refreshToken) pm.collectionVariables.set('refreshToken', refreshToken);",
                  "if (!accessToken) {",
                  "    console.warn('No accessToken cookie captured. The server sets cookies with Secure=true, which are not stored over http://localhost. See the README/notes.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Logs in a user. Body: { email, password }. On success sets httpOnly `accessToken` (1h) and `refreshToken` (7d) cookies and returns the user."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh-token"]
            },
            "description": "Issues new tokens. Requires a valid `refreshToken` cookie (set by Login). No request body needed."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Logs out the current user and clears the `accessToken` / `refreshToken` cookies."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "description": "Protected routes. Require a valid `accessToken` cookie (set by Login).",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Creates a user (admin only). Body: { email, password, role? }."
          },
          "response": []
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Returns all users ordered by createdAt desc."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "<user-uuid>" }]
            },
            "description": "Returns a single user by id."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Workouts",
      "description": "Protected routes. Require a valid `accessToken` cookie (set by Login).",
      "item": [
        {
          "name": "Create Workout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workoutType\": \"PUSHUP\",\n  \"count\": 20\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/workouts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workouts"]
            },
            "description": "Creates a workout for the authenticated user. Body: { workoutType, count }. workoutType: PUSHUP, SQUAT, SITUP, or PLANK."
          },
          "response": []
        },
        {
          "name": "Get Workouts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/workouts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workouts"]
            },
            "description": "Returns all workouts ordered by createdAt desc."
          },
          "response": []
        }
      ]
    }
  ]
}
